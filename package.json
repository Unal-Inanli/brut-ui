{
  "name": "@sprtn/ui",
  "version": "1.3.2",
  "type": "module",
  "description": "Neo-brutalist UI kit. One CSS file + one optional JS runtime for interactive form components.",
  "main": "dist/brut.js",
  "module": "dist/brut.esm.js",
  "style": "dist/brut.css",
  "bin": {
    "brut": "./bin/brut.js"
  },
  "exports": {
    ".": {
      "import": "./dist/brut.esm.js",
      "require": "./dist/brut.js",
      "style": "./dist/brut.css"
    },
    "./css": "./dist/brut.css",
    "./config": "./src/config/define.js",
    "./vite": "./src/config/vite-plugin.js",
    "./manifest": "./dist/components.json"
  },
  "sideEffects": true,
  "files": [
    "dist/",
    "src/",
    "bin/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "bootstrap": "node scripts/bootstrap.js",
    "prepare": "node scripts/post-install-notice.js",
    "check": "node scripts/check-manifest.js && node scripts/check-css-constraints.js",
    "check:doctor": "node bin/brut.js doctor",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test tests/smoke/preview.spec.js",
    "test:a11y": "playwright test tests/smoke/a11y.spec.js",
    "test:behavior": "playwright test tests/behavior",
    "test:visual": "playwright test tests/visual",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "test:size": "size-limit"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^11.2.0",
    "@sprtn/mcp": "workspace:*",
    "happy-dom": "^15.11.7",
    "size-limit": "^11.2.0",
    "vite": "^8.0.10",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "vite": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
